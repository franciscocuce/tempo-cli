{
  "name": "tempo",
  "version": "0.1.0",
  "description": "Scheduler tipo cron hecho desde cero en Node + TypeScript",
  "type": "module",
  "bin": {
    "tempo": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "cli": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "tsx src/index.ts serve",
    "dashboard:dev": "npm --prefix dashboard run dev",
    "dashboard:build": "npm --prefix dashboard run build",
    "web": "npm run dashboard:build && npm run serve"
  },
  "keywords": [
    "cron",
    "scheduler",
    "cli",
    "typescript"
  ],
  "author": "Francisco Cuce",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "commander": "^13.1.0",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.2"
  }
}
